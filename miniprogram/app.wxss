/* app.wxss - global styles
 * UI baseline follows WeChat Mini Program / WeUI conventions:
 * light gray page background, white cells/cards, WeChat green primary actions,
 * blue-gray link actions, red danger actions, and subtle 1px dividers.
 */
page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  background-color: #F7F8FA;
  color: #191919;
  font-size: 28rpx;
  line-height: 1.6;
}

/* Layout */
.container {
  padding: 24rpx;
  box-sizing: border-box;
}

/* WeUI-like card/cell surface: white background, subtle border, no heavy shadow. */
.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid #EEEEEE;
  box-shadow: none;
}

/* Buttons: 44px primary height with compact radius, matching common Mini Program controls. */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border-radius: 8rpx;
  font-size: 32rpx;
  font-weight: 500;
  transition: all 0.3s;
}

.btn-primary {
  background: #07C160;
  color: #fff;
}

.btn-primary:active {
  opacity: 0.8;
}

.btn-secondary {
  background: #F0FFF7;
  color: #576B95;
  border: 1rpx solid #D8D8D8;
}

.btn-danger {
  background: #FA5151;
  color: #fff;
}

/* Inputs: 44px height, fine border, and green focus feedback. */
.input-group {
  margin-bottom: 30rpx;
}

.input-label {
  display: block;
  margin-bottom: 12rpx;
  color: #666666;
  font-size: 28rpx;
}

.input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  border: 2rpx solid #D8D8D8;
  border-radius: 12rpx;
  font-size: 30rpx;
  box-sizing: border-box;
  transition: border-color 0.3s;
}

.input:focus {
  border-color: #07C160;
}

/* Switches */
.switch-container {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
}

/* Lists */
.list-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.list-item:last-child {
  border-bottom: none;
}

/* Empty state */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
  color: #999;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 20rpx;
}

/* Loading */
.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  color: #999;
}

/* Tags */
.tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  margin-right: 12rpx;
}

.tag-primary {
  background: #F0FFF7;
  color: #07C160;
}

.tag-success {
  background: #EDF6FF;
  color: #0B78D0;
}

.tag-warning {
  background: #fff3e0;
  color: #f57c00;
}

/* Text utilities */
.text-center {
  text-align: center;
}

.text-right {
  text-align: right;
}

.text-muted {
  color: #999;
}

.text-primary {
  color: #07C160;
}

.text-danger {
  color: #FA5151;
}

/* Spacing utilities */
.mt-10 { margin-top: 10rpx; }
.mt-20 { margin-top: 20rpx; }
.mt-30 { margin-top: 30rpx; }

.mb-10 { margin-bottom: 10rpx; }
.mb-20 { margin-bottom: 20rpx; }
.mb-30 { margin-bottom: 30rpx; }

/* Flex layout */
.flex {
  display: flex;
}

.flex-1 {
  flex: 1;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.flex-wrap {
  flex-wrap: wrap;
}

/* Bottom action bar */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #E5E5E5;
  box-shadow: none;
  display: flex;
  gap: 20rpx;
}

.bottom-bar .btn {
  flex: 1;
}

/* Checkbox */
.checkbox {
  width: 44rpx;
  height: 44rpx;
  border: 2rpx solid #ddd;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  transition: all 0.2s;
}

.checkbox.checked {
  background: #07C160;
  border-color: #07C160;
  color: #fff;
}

/* Swipe delete */
.swipe-item {
  position: relative;
  overflow: hidden;
}

.swipe-content {
  transition: transform 0.3s;
}

.swipe-delete {
  position: absolute;
  right: 0;
  top: 0;
  bottom: 0;
  width: 160rpx;
  background: #FA5151;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
}

