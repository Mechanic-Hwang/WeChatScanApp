/* pages/settings/settings.wxss
 * Settings uses a WeUI cell-like layout: grouped white panels, thin dividers,
 * restrained radius, green selected state, and blue-gray secondary actions.
 */
/* Group panel: behaves like a WeUI cell group rather than a decorative card. */
.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 0 32rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid #EEEEEE;
  box-shadow: none;
}

.card-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #191919;
  margin-bottom: 0;
}

.card-desc {
  font-size: 26rpx;
  color: #8A8A8A;
  margin: 0 0 24rpx;
  line-height: 1.5;
}

/* Expand/collapse header: simple tappable cell with a chevron indicator. */
.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 104rpx;
  border-bottom: 1rpx solid #EEEEEE;
}

.toggle-control {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* Chevron is CSS-only to keep the dropdown control compact and consistent. */
.toggle-icon {
  width: 18rpx;
  height: 18rpx;
  border-right: 3rpx solid #B2B2B2;
  border-bottom: 3rpx solid #B2B2B2;
  transform: rotate(45deg);
  transition: transform 0.2s ease;
}

.toggle-control.expanded .toggle-icon {
  transform: rotate(225deg);
}

/* Password input keeps the visibility action inside the input touch area. */
.password-input {
  position: relative;
}

.password-input .input {
  padding-right: 80rpx;
}

.eye-icon {
  position: absolute;
  right: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 40rpx;
  padding: 10rpx;
}

/* Legacy test section divider. */
.test-section {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

/* Language list uses full-width rows with subtle dividers. */
.language-list {
  margin-top: 10rpx;
}

.language-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #EEEEEE;
}

.language-item:last-child {
  border-bottom: none;
}

.language-item.active {
  color: #07C160;
}

.lang-name {
  font-size: 30rpx;
}

.lang-check {
  font-size: 32rpx;
  font-weight: bold;
}

/* Data actions are list cells; red is reserved for destructive flows. */
.data-actions {
  margin-top: 10rpx;
}

.action-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #EEEEEE;
}

.action-item:last-child {
  border-bottom: none;
}

.action-content {
  flex: 1;
}

.action-symbol {
  position: relative;
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #F7F8FA;
  color: #576B95;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.delete-symbol {
  background: #FFF2F2;
  color: #FA5151;
}

.delete-symbol-lid {
  position: absolute;
  left: 15rpx;
  top: 14rpx;
  width: 26rpx;
  height: 4rpx;
  border-radius: 4rpx;
  background: currentColor;
}

.delete-symbol-body {
  position: absolute;
  left: 17rpx;
  top: 22rpx;
  width: 22rpx;
  height: 22rpx;
  border: 3rpx solid currentColor;
  border-top: none;
  border-radius: 0 0 5rpx 5rpx;
  box-sizing: border-box;
}

.export-symbol-box {
  position: absolute;
  left: 16rpx;
  bottom: 13rpx;
  width: 24rpx;
  height: 18rpx;
  border: 3rpx solid currentColor;
  border-top: none;
  border-radius: 0 0 5rpx 5rpx;
  box-sizing: border-box;
}

.export-symbol-arrow {
  position: absolute;
  left: 26rpx;
  top: 12rpx;
  width: 4rpx;
  height: 24rpx;
  border-radius: 4rpx;
  background: currentColor;
}

.export-symbol-arrow::before,
.export-symbol-arrow::after {
  content: '';
  position: absolute;
  top: 0;
  width: 12rpx;
  height: 4rpx;
  border-radius: 4rpx;
  background: currentColor;
}

.export-symbol-arrow::before {
  right: -1rpx;
  transform: rotate(45deg);
}

.export-symbol-arrow::after {
  left: -1rpx;
  transform: rotate(-45deg);
}

.reset-symbol-ring {
  position: absolute;
  left: 14rpx;
  top: 14rpx;
  width: 28rpx;
  height: 28rpx;
  border: 3rpx solid currentColor;
  border-right-color: transparent;
  border-radius: 50%;
  box-sizing: border-box;
}

.reset-symbol-arrow {
  position: absolute;
  right: 12rpx;
  top: 15rpx;
  width: 11rpx;
  height: 11rpx;
  border-top: 3rpx solid currentColor;
  border-right: 3rpx solid currentColor;
  transform: rotate(25deg);
  box-sizing: border-box;
}

.action-title {
  display: block;
  font-size: 30rpx;
  color: #191919;
  margin-bottom: 8rpx;
}

.action-desc {
  display: block;
  font-size: 24rpx;
  color: #8A8A8A;
}

.action-arrow {
  width: 16rpx;
  height: 16rpx;
  border-right: 3rpx solid #C9CDD4;
  border-bottom: 3rpx solid #C9CDD4;
  transform: rotate(-45deg);
  margin-left: 20rpx;
  flex-shrink: 0;
}

/* Switch rows: label on the left, native switch aligned right. */
.switch-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #EEEEEE;
}

.switch-item:last-child {
  border-bottom: none;
}

.switch-label {
  font-size: 30rpx;
  color: #191919;
}

/* Switch list spacing. */
.switch-list {
  margin-top: 10rpx;
}

.switch-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #EEEEEE;
}

.switch-item:last-child {
  border-bottom: none;
}

.switch-info {
  flex: 1;
}

.switch-name {
  display: block;
  font-size: 30rpx;
  color: #191919;
}

.switch-desc {
  display: block;
  font-size: 24rpx;
  color: #8A8A8A;
  margin-top: 4rpx;
}

/* Segmented/radio controls: neutral base, green selected state. */
.radio-group {
  margin-top: 10rpx;
}

.radio-group.inline {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.radio-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background: #F7F8FA;
  border-radius: 8rpx;
  margin-bottom: 16rpx;
  border: 2rpx solid transparent;
}

.radio-group.inline .radio-item {
  flex: 1;
  min-width: 120rpx;
  margin-bottom: 0;
  justify-content: center;
}

.radio-item.active {
  border-color: #07C160;
  background: #F0FFF7;
  color: #07C160;
}

.radio-name {
  font-size: 30rpx;
  color: #191919;
}

.radio-desc {
  font-size: 24rpx;
  color: #8A8A8A;
  margin-top: 4rpx;
}

/* About block uses the same text scale and color system. */
.about-info {
  text-align: center;
  padding: 30rpx 0;
}

.app-name {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
  color: #191919;
  margin-bottom: 12rpx;
}

.app-version {
  display: block;
  font-size: 26rpx;
  color: #8A8A8A;
  margin-bottom: 16rpx;
}

.app-desc {
  display: block;
  font-size: 26rpx;
  color: #666666;
}

.input-tip {
  display: block;
  color: #8A8A8A;
  font-size: 24rpx;
  line-height: 1.5;
  margin-top: 12rpx;
}

.field-option-list {
  background: #fff;
  border: 1rpx solid #EEEEEE;
  border-radius: 8rpx;
  margin-top: 12rpx;
  padding: 0 20rpx;
}

.field-option {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 88rpx;
  border-bottom: 1rpx solid #EEEEEE;
  color: #191919;
  font-size: 28rpx;
}

.field-option:last-child {
  border-bottom: none;
}

.config-chip-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin: 16rpx 0;
}

.config-chip {
  background: #F7F8FA;
  border: 1rpx solid #D8D8D8;
  border-radius: 8rpx;
  color: #666666;
  font-size: 24rpx;
  padding: 10rpx 18rpx;
}

.config-chip.active {
  background: #F0FFF7;
  border-color: #07C160;
  color: #07C160;
}

.inline-actions {
  display: flex;
  gap: 16rpx;
}

.inline-actions .btn {
  flex: 1;
  height: 80rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
}

.pair-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.pair-input {
  flex: 1;
  height: 88rpx;
  border: 1rpx solid #D8D8D8;
  border-radius: 8rpx;
  background: #fff;
  color: #191919;
  font-size: 28rpx;
  padding: 0 16rpx;
  box-sizing: border-box;
}

.pair-delete {
  color: #FA5151;
  font-size: 24rpx;
  padding: 12rpx 0;
}

.textarea-input {
  min-height: 176rpx;
  height: auto;
  line-height: 1.5;
  padding-top: 20rpx;
  padding-bottom: 20rpx;
}

.rule-card {
  background: #fff;
  border: 1rpx solid #EEEEEE;
  border-radius: 8rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.test-result {
  margin-top: 20rpx;
  background: #F7F8FA;
  border: 1rpx solid #EEEEEE;
  border-radius: 8rpx;
  padding: 24rpx;
}

.result-title {
  color: #191919;
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 14rpx;
}

.result-meta {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  color: #666666;
  font-size: 24rpx;
  margin-bottom: 16rpx;
}

.result-section {
  margin-top: 18rpx;
}

.result-label {
  color: #576B95;
  display: block;
  font-size: 24rpx;
  font-weight: 600;
  margin-bottom: 10rpx;
}

.result-field,
.preview-field {
  display: flex;
  gap: 16rpx;
  padding: 10rpx 0;
  border-bottom: 1rpx solid #EEEEEE;
}

.result-field:last-child,
.preview-field:last-child {
  border-bottom: none;
}

.field-name,
.preview-label {
  color: #666666;
  flex: 0 0 180rpx;
  font-size: 24rpx;
}

.field-value,
.preview-value {
  color: #191919;
  flex: 1;
  font-size: 24rpx;
  word-break: break-all;
}

.raw-response {
  box-sizing: border-box;
  max-height: 260rpx;
  width: 100%;
  background: #fff;
  border: 1rpx solid #D8D8D8;
  border-radius: 8rpx;
  color: #191919;
  font-size: 22rpx;
  line-height: 1.5;
  padding: 16rpx;
  white-space: pre-wrap;
  word-break: break-all;
}

.error-message {
  color: #FA5151;
  font-size: 24rpx;
  line-height: 1.5;
}
