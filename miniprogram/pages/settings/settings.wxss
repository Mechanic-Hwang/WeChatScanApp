/* pages/settings/settings.wxss */
.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid #E6F0FF;
  box-shadow: 0 4rpx 18rpx rgba(29, 111, 234, 0.06);
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1F2329;
  margin-bottom: 12rpx;
}

.card-desc {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 24rpx;
}

/* 密码输入框 */
.password-input {
  position: relative;
}

.password-input .input {
  padding-right: 80rpx;
}

.eye-icon {
  position: absolute;
  right: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 40rpx;
  padding: 10rpx;
}

/* 测试区域 */
.test-section {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

/* 语言列表 */
.language-list {
  margin-top: 10rpx;
}

.language-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.language-item:last-child {
  border-bottom: none;
}

.language-item.active {
  color: #1D6FEA;
}

.lang-name {
  font-size: 30rpx;
}

.lang-check {
  font-size: 32rpx;
  font-weight: bold;
}

/* 数据操作 */
.data-actions {
  margin-top: 10rpx;
}

.action-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.action-item:last-child {
  border-bottom: none;
}

.action-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.action-content {
  flex: 1;
}

.action-title {
  display: block;
  font-size: 30rpx;
  color: #1F2329;
  margin-bottom: 8rpx;
}

.action-desc {
  display: block;
  font-size: 24rpx;
  color: #999;
}

.action-arrow {
  color: #ccc;
  font-size: 32rpx;
}

/* 开关项 - 文字左对齐，开关右对齐 */
.switch-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.switch-item:last-child {
  border-bottom: none;
}

.switch-label {
  font-size: 30rpx;
  color: #1F2329;
}

/* 开关列表 */
.switch-list {
  margin-top: 10rpx;
}

.switch-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.switch-item:last-child {
  border-bottom: none;
}

.switch-info {
  flex: 1;
}

.switch-name {
  display: block;
  font-size: 30rpx;
  color: #1F2329;
}

.switch-desc {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}

/* 单选组 */
.radio-group {
  margin-top: 10rpx;
}

.radio-group.inline {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.radio-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background: #F7FAFF;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
  border: 2rpx solid transparent;
}

.radio-group.inline .radio-item {
  flex: 1;
  min-width: 120rpx;
  margin-bottom: 0;
  justify-content: center;
}

.radio-item.active {
  border-color: #1D6FEA;
  background: #EAF2FF;
}

.radio-name {
  font-size: 30rpx;
  color: #1F2329;
}

.radio-desc {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}

/* 关于 */
.about-info {
  text-align: center;
  padding: 30rpx 0;
}

.app-name {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
  color: #1F2329;
  margin-bottom: 12rpx;
}

.app-version {
  display: block;
  font-size: 26rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.app-desc {
  display: block;
  font-size: 26rpx;
  color: #4E5969;
}
