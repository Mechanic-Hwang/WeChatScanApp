<!-- pages/settings/settings.wxml -->
<view class="container">
  <!-- 高级API配置 -->
  <view class="card dropdown-card">
    <view class="card-header" bindtap="toggleAdvancedConfig">
      <view class="card-title">{{t.advancedApiConfig}}</view>
      <view class="toggle-control {{showAdvancedConfig ? 'expanded' : ''}}">
        <text class="toggle-icon"></text>
      </view>
    </view>
    <view class="card-desc">{{t.advancedApiDesc}}</view>
    <view class="advanced-content {{showAdvancedConfig ? 'expanded' : 'collapsed'}}" wx:if="{{advancedConfigVisible}}">

    <view class="config-section">
      <view class="section-title">{{t.apiConfigList}}</view>
      <view class="config-chip-list">
        <view class="config-chip {{activeApiConfigId === item.apiConfigId ? 'active' : ''}}"
              wx:for="{{apiConfigs}}"
              wx:key="apiConfigId"
              bindtap="selectApiConfig"
              data-id="{{item.apiConfigId}}">
          {{item.name || item.apiConfigId}}{{item.isDefault ? t.defaultApiSuffix : ''}}
        </view>
      </view>
      <view class="inline-actions">
        <view class="btn btn-secondary" bindtap="addApiConfig">{{t.addApi}}</view>
        <view class="btn btn-danger" bindtap="deleteApiConfig">{{t.deleteCurrent}}</view>
      </view>
    </view>
    
    <!-- 基础配置 -->
    <view class="config-section">
      <view class="section-title">{{t.requestConfig}}</view>

      <view class="switch-item">
        <text class="switch-label">{{t.enableCurrentApi}}</text>
        <switch checked="{{apiConfig.enabled}}" bindchange="toggleApiEnabled"/>
      </view>

      <view class="switch-item">
        <view class="switch-info">
          <text class="switch-name">{{t.defaultApi}}</text>
          <text class="switch-desc">{{t.defaultApiDesc}}</text>
        </view>
        <switch checked="{{apiConfig.isDefault}}" bindchange="setDefaultApi"/>
      </view>
      
      <view class="input-group">
        <text class="input-label">{{t.apiName}}</text>
        <input class="input" 
               type="text" 
               placeholder="{{t.apiNamePlaceholder}}"
               value="{{apiConfig.name}}"
               bindinput="onApiNameInput"/>
      </view>
      
      <view class="input-group">
        <text class="input-label">{{t.requestUrl}}</text>
        <input class="input" 
               type="text" 
               placeholder="https://example.com/api/book"
               value="{{apiConfig.url}}"
               bindinput="onApiUrlInput"/>
        <text class="input-tip">{{t.requestUrlTip}}</text>
      </view>
      
      <view class="input-group">
        <text class="input-label">{{t.requestMethod}}</text>
        <view class="radio-group inline">
          <view class="radio-item {{apiConfig.method === 'GET' ? 'active' : ''}}" bindtap="setApiMethod" data-method="GET">GET</view>
          <view class="radio-item {{apiConfig.method === 'POST' ? 'active' : ''}}" bindtap="setApiMethod" data-method="POST">POST</view>
        </view>
      </view>
      
      <view class="input-group">
        <text class="input-label">{{t.requestFormat}}</text>
        <view class="radio-group inline">
          <view class="radio-item {{apiConfig.requestType === 'query' ? 'active' : ''}}" bindtap="setRequestType" data-type="query">{{t.queryParams}}</view>
          <view class="radio-item {{apiConfig.requestType === 'json' ? 'active' : ''}}" bindtap="setRequestType" data-type="json">{{t.jsonBody}}</view>
        </view>
      </view>
      
      <view class="input-group">
        <text class="input-label">{{t.timeout}}</text>
        <view class="radio-group inline">
          <view class="radio-item {{apiConfig.timeout === 3000 ? 'active' : ''}}" bindtap="setTimeout" data-timeout="3000">3s</view>
          <view class="radio-item {{apiConfig.timeout === 5000 ? 'active' : ''}}" bindtap="setTimeout" data-timeout="5000">5s</view>
          <view class="radio-item {{apiConfig.timeout === 10000 ? 'active' : ''}}" bindtap="setTimeout" data-timeout="10000">10s</view>
        </view>
      </view>

      <view class="input-group">
        <text class="input-label">{{t.responseFormat}}</text>
        <view class="radio-group inline">
          <view class="radio-item {{apiConfig.responseType === 'json' ? 'active' : ''}}" bindtap="setResponseType" data-type="json">JSON</view>
          <view class="radio-item {{apiConfig.responseType === 'xml' ? 'active' : ''}}" bindtap="setResponseType" data-type="xml">XML</view>
          <view class="radio-item {{apiConfig.responseType === 'auto' ? 'active' : ''}}" bindtap="setResponseType" data-type="auto">{{t.autoDetect}}</view>
        </view>
      </view>

      <view class="input-group">
        <text class="input-label">{{t.emptyValueHandling}}</text>
        <view class="radio-group inline">
          <view class="radio-item {{apiConfig.emptyValueMode === 'placeholder' ? 'active' : ''}}" bindtap="setEmptyValueMode" data-mode="placeholder">{{t.showPlaceholder}}</view>
          <view class="radio-item {{apiConfig.emptyValueMode === 'hide' ? 'active' : ''}}" bindtap="setEmptyValueMode" data-mode="hide">{{t.hideField}}</view>
        </view>
      </view>

      <view class="switch-item">
        <view class="switch-info">
          <text class="switch-name">{{t.showRawResponse}}</text>
          <text class="switch-desc">{{t.showRawResponseDesc}}</text>
        </view>
        <switch checked="{{apiConfig.showRawResponse}}" bindchange="toggleShowRawResponse"/>
      </view>
    </view>

    <view class="config-section">
      <view class="section-title">{{t.queryParams}}</view>
      <view class="pair-row" wx:for="{{apiConfig.queryParams}}" wx:key="index">
        <input class="pair-input" placeholder="key" value="{{item.key}}" data-index="{{index}}" data-field="key" bindinput="onQueryParamChange"/>
        <input class="pair-input" placeholder="{{scanValue}}" value="{{item.value}}" data-index="{{index}}" data-field="value" bindinput="onQueryParamChange"/>
        <text class="pair-delete" bindtap="deleteQueryParam" data-index="{{index}}">{{t.delete}}</text>
      </view>
      <view class="btn btn-secondary mt-20" bindtap="addQueryParam">{{t.addQueryParam}}</view>
    </view>

    <view class="config-section">
      <view class="section-title">{{t.headerConfig}}</view>
      <view class="pair-row" wx:for="{{headerItems}}" wx:key="index">
        <input class="pair-input" placeholder="{{t.headerName}}" value="{{item.key}}" data-index="{{index}}" data-field="key" bindinput="onHeaderChange"/>
        <input class="pair-input" placeholder="{{t.headerValue}}" value="{{item.value}}" data-index="{{index}}" data-field="value" bindinput="onHeaderChange"/>
        <text class="pair-delete" bindtap="deleteHeader" data-index="{{index}}">{{t.delete}}</text>
      </view>
      <view class="btn btn-secondary mt-20" bindtap="addHeader">{{t.addHeader}}</view>
    </view>

    <view class="config-section" wx:if="{{apiConfig.requestType === 'json'}}">
      <view class="section-title">JSON Body</view>
      <textarea class="input textarea-input"
                value="{{apiConfig.jsonBodyTemplate}}"
                bindinput="onJsonBodyInput"
                placeholder='{"barcode":"{{scanValue}}"}'
                auto-height/>
      <text class="input-tip">{{t.scanValueTip}}</text>
    </view>
    
    <!-- 字段映射 -->
    <view class="config-section">
      <view class="section-title">{{t.fieldMapping}}</view>
      <view class="field-list">
        <view class="field-item header">
          <text class="field-label">{{t.fieldLabel}}</text>
          <text class="field-path">{{t.fieldPath}}</text>
          <text class="field-visible">{{t.fieldVisible}}</text>
        </view>
        <view class="field-item" wx:for="{{apiConfig.fieldMappings}}" wx:key="index">
          <input class="field-input"
                 placeholder="{{t.bookTitle}}"
                 value="{{item.label}}"
                 data-index="{{index}}"
                 data-field="label"
                 bindinput="onFieldChange"/>
          <input class="field-input"
                 placeholder="data.title"
                 value="{{item.path}}"
                 data-index="{{index}}"
                 data-field="path"
                 bindinput="onFieldChange"/>
          <switch class="field-switch"
                  checked="{{item.visible}}"
                  data-index="{{index}}"
                  bindchange="onFieldVisibleChange"/>
        </view>
      </view>
      <view class="btn btn-secondary mt-20" bindtap="addFieldMapping">{{t.addField}}</view>
    </view>
    
    <!-- 测试区域 -->
    <view class="config-section">
      <view class="section-title">{{t.testPreview}}</view>
      <view class="input-group">
        <text class="input-label">{{t.testValue}}</text>
        <input class="input"
               type="text"
               placeholder="{{t.testValuePlaceholder}}"
               value="{{testValue}}"
               bindinput="onTestValueInput"/>
      </view>
      <view class="btn btn-primary mt-20" bindtap="testApiConfig">{{t.testBtn}}</view>
      
      <!-- 测试结果 -->
      <view class="test-result" wx:if="{{testResult}}">
        <view wx:if="{{testResult.success}}">
          <view class="result-title">✅ {{t.testSuccess}}</view>
          <view class="result-meta">
            <text>{{t.apiConfigUsed.replace('{name}', testResult.apiConfigName)}}</text>
            <text>{{t.detectedResponseType.replace('{type}', testResult.detectedType)}}</text>
          </view>
          <view class="result-section">
            <text class="result-label">{{t.parsedResult}}</text>
            <view class="result-fields">
              <view class="result-field" wx:for="{{testResult.parsedFields}}" wx:key="label">
                <text class="field-name">{{item.label}}：</text>
                <text class="field-value">{{item.value || t.noData}}</text>
              </view>
            </view>
          </view>
          <view class="result-section">
            <text class="result-label">{{t.finalPreview}}</text>
            <view class="preview-fields">
              <view class="preview-field" wx:for="{{testResult.displayFields}}" wx:key="label">
                <text class="preview-label">{{item.label}}</text>
                <text class="preview-value">{{item.value || t.noData}}</text>
              </view>
            </view>
          </view>
          <view class="result-section" wx:if="{{apiConfig.showRawResponse}}">
            <text class="result-label">{{t.rawResponse}}</text>
            <scroll-view class="raw-response" scroll-y>{{testResult.rawResponseText}}</scroll-view>
          </view>
        </view>
        <view wx:else>
          <view class="result-title">❌ {{t.testFailed}}</view>
          <text class="error-message">{{testResult.error}}</text>
        </view>
      </view>
    </view>
    
    <view class="btn btn-primary mt-30" bindtap="saveAdvancedApiConfig">{{t.saveAdvancedConfig}}</view>
    </view>
  </view>

  <view class="card">
    <view class="card-title">{{t.routeRules}}</view>
    <view class="card-desc">{{t.routeRulesDesc}}</view>

    <view class="rule-card" wx:for="{{scanRules}}" wx:key="ruleId">
      <view class="switch-item">
        <view class="switch-info">
          <text class="switch-name">{{item.name || t.unnamedRule}}</text>
          <text class="switch-desc">{{t.boundApi.replace('{apiConfigId}', item.apiConfigId || t.unbound)}}</text>
        </view>
        <switch checked="{{item.enabled}}" data-index="{{index}}" bindchange="toggleScanRule"/>
      </view>

      <view class="input-group">
        <text class="input-label">{{t.ruleName}}</text>
        <input class="input" value="{{item.name}}" data-index="{{index}}" data-field="name" bindinput="onScanRuleChange"/>
      </view>
      <view class="input-group">
        <text class="input-label">{{t.regexPattern}}</text>
        <input class="input" placeholder="^A\\d{9}$" value="{{item.pattern}}" data-index="{{index}}" data-field="pattern" bindinput="onScanRuleChange"/>
      </view>
      <view class="input-group">
        <text class="input-label">{{t.priority}}</text>
        <input class="input" type="number" value="{{item.priority}}" data-index="{{index}}" data-field="priority" bindinput="onScanRuleChange"/>
      </view>
      <view class="input-group">
        <text class="input-label">{{t.bindApiId}}</text>
        <input class="input" value="{{item.apiConfigId}}" data-index="{{index}}" data-field="apiConfigId" bindinput="onScanRuleChange"/>
        <view class="btn btn-secondary mt-20" bindtap="bindRuleToActiveApi" data-index="{{index}}">{{t.bindCurrentApi}}</view>
      </view>
      <view class="btn btn-danger mt-20" bindtap="deleteScanRule" data-index="{{index}}">{{t.deleteRule}}</view>
    </view>

    <view class="inline-actions mt-20">
      <view class="btn btn-secondary" bindtap="addScanRule">{{t.addRule}}</view>
      <view class="btn btn-primary" bindtap="saveScanRules">{{t.saveRules}}</view>
    </view>
  </view>

  <!-- 语言设置 -->
  <view class="card">
    <view class="card-title">{{t.languageSetting}}</view>
    <view class="language-list">
      <view class="language-item {{languageMode === 'system' ? 'active' : ''}}"
            bindtap="switchLanguage"
            data-lang="system">
        <text class="lang-name">{{t.langSystem}}</text>
        <text class="lang-check" wx:if="{{languageMode === 'system'}}">✓</text>
      </view>
      <view class="language-item {{languageMode === 'manual' && currentLang === 'zh-CN' ? 'active' : ''}}" 
            bindtap="switchLanguage" 
            data-lang="zh-CN">
        <text class="lang-name">{{t.langZhCN}}</text>
        <text class="lang-check" wx:if="{{languageMode === 'manual' && currentLang === 'zh-CN'}}">✓</text>
      </view>
      <view class="language-item {{languageMode === 'manual' && currentLang === 'zh-TW' ? 'active' : ''}}" 
            bindtap="switchLanguage" 
            data-lang="zh-TW">
        <text class="lang-name">{{t.langZhTW}}</text>
        <text class="lang-check" wx:if="{{languageMode === 'manual' && currentLang === 'zh-TW'}}">✓</text>
      </view>
      <view class="language-item {{languageMode === 'manual' && currentLang === 'en' ? 'active' : ''}}" 
            bindtap="switchLanguage" 
            data-lang="en">
        <text class="lang-name">{{t.langEn}}</text>
        <text class="lang-check" wx:if="{{languageMode === 'manual' && currentLang === 'en'}}">✓</text>
      </view>
    </view>
  </view>

  <!-- 输入规则配置 -->
  <view class="card">
    <view class="card-title">{{t.inputRules}}</view>
    <view class="card-desc">{{t.inputRulesDesc}}</view>

    <view class="switch-item">
      <text class="switch-label">{{t.trimSpace}}</text>
      <switch checked="{{inputRules.trimSpace}}" bindchange="toggleTrimSpace"/>
    </view>

    <view class="switch-item">
      <text class="switch-label">{{t.uppercase}}</text>
      <switch checked="{{inputRules.uppercase}}" bindchange="toggleUppercase"/>
    </view>

    <view class="switch-item">
      <text class="switch-label">{{t.isbnRequired}}</text>
      <switch checked="{{inputRules.isbnRequired}}" bindchange="toggleIsbnRequired"/>
    </view>

    <view class="switch-item">
      <text class="switch-label">{{t.allowNewline}}</text>
      <switch checked="{{inputRules.allowNewline}}" bindchange="toggleAllowNewline"/>
    </view>

    <view class="switch-item" wx:if="{{!inputRules.allowNewline}}">
      <text class="switch-label">{{t.enterSubmit}}</text>
      <switch checked="{{inputRules.enterSubmit}}" bindchange="toggleEnterSubmit"/>
    </view>

    <view class="switch-note" wx:else>
      <text>{{t.enterSubmitDisabledInMultiline}}</text>
    </view>

    <view class="input-group mt-20">
      <text class="input-label">{{t.maxInputLength}}</text>
      <view class="radio-group inline">
        <view class="radio-item {{inputRules.maxLength === 50 ? 'active' : ''}}" bindtap="setMaxInputLength" data-length="50">50</view>
        <view class="radio-item {{inputRules.maxLength === 100 ? 'active' : ''}}" bindtap="setMaxInputLength" data-length="100">100</view>
        <view class="radio-item {{inputRules.maxLength === 200 ? 'active' : ''}}" bindtap="setMaxInputLength" data-length="200">200</view>
        <view class="radio-item {{inputRules.maxLength === 500 ? 'active' : ''}}" bindtap="setMaxInputLength" data-length="500">500</view>
        <view class="radio-item {{inputRules.maxLength === 1000 ? 'active' : ''}}" bindtap="setMaxInputLength" data-length="1000">1000</view>
      </view>
      <text class="input-tip">{{t.maxInputLengthTip}}</text>
    </view>
  </view>

  <!-- 复制规则配置 -->
  <view class="card">
    <view class="card-title">{{t.copyRules}}</view>
    <view class="card-desc">{{t.copyRulesDesc}}</view>

    <view class="input-group">
      <text class="input-label">{{t.copyRange}}</text>
      <view class="radio-group inline">
        <view class="radio-item {{copyRules.range === 'raw' ? 'active' : ''}}" bindtap="setCopyRange" data-range="raw">{{t.rawContent}}</view>
        <view class="radio-item {{copyRules.range === 'primary' ? 'active' : ''}}" bindtap="setCopyRange" data-range="primary">{{t.primaryFields}}</view>
        <view class="radio-item {{copyRules.range === 'full' ? 'active' : ''}}" bindtap="setCopyRange" data-range="full">{{t.fullDetail}}</view>
        <view class="radio-item {{copyRules.range === 'json' ? 'active' : ''}}" bindtap="setCopyRange" data-range="json">JSON</view>
      </view>
      <text class="input-tip">{{t.copyRangeTip}}</text>
    </view>

    <view class="input-group">
      <text class="input-label">{{t.copySeparator}}</text>
      <view class="radio-group inline">
        <view class="radio-item {{copyRules.separator === 'singleNewline' ? 'active' : ''}}" bindtap="setCopySeparator" data-separator="singleNewline">{{t.singleNewline}}</view>
        <view class="radio-item {{copyRules.separator === 'blankLine' ? 'active' : ''}}" bindtap="setCopySeparator" data-separator="blankLine">{{t.blankLine}}</view>
        <view class="radio-item {{copyRules.separator === 'line' ? 'active' : ''}}" bindtap="setCopySeparator" data-separator="line">---</view>
      </view>
      <text class="input-tip">{{t.copySeparatorTip}}</text>
    </view>

    <view class="switch-list">
      <view class="switch-item">
        <view class="switch-info">
          <text class="switch-name">{{t.includeTime}}</text>
          <text class="switch-desc">{{t.includeTimeDesc}}</text>
        </view>
        <switch checked="{{copyRules.includeTime}}" bindchange="toggleCopyIncludeTime"/>
      </view>
      <view class="switch-item">
        <view class="switch-info">
          <text class="switch-name">{{t.includeMode}}</text>
          <text class="switch-desc">{{t.includeModeDesc}}</text>
        </view>
        <switch checked="{{copyRules.includeMode}}" bindchange="toggleCopyIncludeMode"/>
      </view>
    </view>

    <view class="input-group mt-20">
      <text class="input-label">{{t.bookCopyFields}}</text>
      <view class="field-option-list">
        <view class="field-option" wx:for="{{bookFieldOptions}}" wx:key="key">
          <text>{{item.label}}</text>
          <switch checked="{{item.checked}}" data-field="{{item.key}}" bindchange="toggleBookCopyField"/>
        </view>
      </view>
      <text class="input-tip">{{t.bookCopyFieldsTip}}</text>
    </view>
  </view>

  <!-- 数据管理 -->
  <view class="card">
    <view class="card-title">{{t.dataManagement}}</view>
    <view class="data-actions">
      <view class="action-item" bindtap="clearHistory">
        <view class="action-symbol delete-symbol">
          <view class="delete-symbol-lid"></view>
          <view class="delete-symbol-body"></view>
        </view>
        <view class="action-content">
          <text class="action-title">{{t.clearHistory}}</text>
          <text class="action-desc">{{t.clearDesc}}</text>
        </view>
        <view class="action-arrow"></view>
      </view>

      <view class="action-item" bindtap="exportData">
        <view class="action-symbol export-symbol">
          <view class="export-symbol-box"></view>
          <view class="export-symbol-arrow"></view>
        </view>
        <view class="action-content">
          <text class="action-title">{{t.exportData}}</text>
          <text class="action-desc">{{t.exportDesc}}</text>
        </view>
        <view class="action-arrow"></view>
      </view>

      <view class="action-item" bindtap="resetAllSettings">
        <view class="action-symbol reset-symbol">
          <view class="reset-symbol-ring"></view>
          <view class="reset-symbol-arrow"></view>
        </view>
        <view class="action-content">
          <text class="action-title">{{t.resetSettings}}</text>
          <text class="action-desc">{{t.resetSettingsDesc}}</text>
        </view>
        <view class="action-arrow"></view>
      </view>
    </view>
  </view>

  <!-- 使用说明 -->
  <view class="card">
    <view class="card-title">{{t.helpTitle}}</view>
    <view class="help-content">
      <view class="help-item">
        <text class="help-title">{{t.normalModeHelp}}</text>
        <text class="help-text">{{t.normalModeHelpText}}</text>
      </view>
      <view class="help-item">
        <text class="help-title">{{t.bookModeHelp}}</text>
        <text class="help-text">{{t.bookModeHelpText}}</text>
      </view>
      <view class="help-item">
        <text class="help-title">{{t.batchHelp}}</text>
        <text class="help-text">{{t.batchHelpText}}</text>
      </view>
    </view>
  </view>

  <!-- 关于 -->
  <view class="card">
    <view class="card-title">{{t.about}}</view>
    <view class="about-info">
      <text class="app-name">{{t.appName}}</text>
      <text class="app-version">{{t.version}}</text>
      <text class="app-desc">{{t.appDesc}}</text>
    </view>
  </view>
</view>
