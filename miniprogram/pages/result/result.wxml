<!-- pages/result/result.wxml -->
<view class="container">
  <!-- 批量操作栏 -->
  <view class="batch-bar" wx:if="{{isBatchMode}}">
    <view class="batch-info">
      <text class="batch-count">已选择 {{selectedCount}} 项</text>
    </view>
    <view class="batch-actions">
      <view class="batch-btn" bindtap="selectAll">{{isAllSelected ? '取消全选' : '全选'}}</view>
      <view class="batch-btn danger" bindtap="deleteSelected">删除</view>
      <view class="batch-btn primary" bindtap="copySelected">复制</view>
    </view>
  </view>

  <!-- 记录列表 -->
  <view class="record-list">
    <view class="record-item {{item.selected ? 'selected' : ''}}" 
          wx:for="{{records}}" 
          wx:key="id"
          bindtap="{{isBatchMode ? 'toggleSelect' : 'viewDetail'}}"
          data-id="{{item.id}}"
          data-index="{{index}}">
      
      <!-- 复选框 -->
      <view class="checkbox {{item.selected ? 'checked' : ''}}" wx:if="{{isBatchMode}}">
        <text wx:if="{{item.selected}}">✓</text>
      </view>
      
      <!-- 内容 -->
      <view class="record-content">
        <view class="record-header">
          <text class="record-type-tag {{item.mode}}">{{item.mode === 'book' ? '图书' : '条码'}}</text>
          <text class="record-time">{{item.time}}</text>
        </view>
        
        <view class="record-title">{{item.title || item.content}}</view>
        
        <view class="record-book-info" wx:if="{{item.mode === 'book' && item.bookInfo}}">
          <text class="book-author" wx:if="{{item.bookInfo.author}}">{{item.bookInfo.author}}</text>
          <text class="book-publisher" wx:if="{{item.bookInfo.publisher}}">{{item.bookInfo.publisher}}</text>
        </view>
      </view>
      
      <!-- 箭头 -->
      <text class="record-arrow" wx:if="{{!isBatchMode}}">></text>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{records.length === 0}}">
    <text class="empty-icon">📭</text>
    <text class="empty-text">暂无记录</text>
  </view>

  <!-- 底部操作栏 -->
  <view class="bottom-bar" wx:if="{{!isBatchMode && records.length > 0}}">
    <view class="btn btn-secondary" bindtap="enterBatchMode">批量操作</view>
    <view class="btn btn-danger" bindtap="clearAll">清空全部</view>
  </view>

  <view class="bottom-bar" wx:if="{{isBatchMode}}">
    <view class="btn btn-secondary" bindtap="exitBatchMode">取消</view>
  </view>
</view>
