/* pages/detail/detail.wxss */
.detail-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.type-tag {
  display: inline-block;
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
  font-size: 26rpx;
}

.type-tag.normal {
  background: #e3f2fd;
  color: #1976d2;
}

.type-tag.book {
  background: #e8f5e9;
  color: #388e3c;
}

.time {
  font-size: 26rpx;
  color: #999;
}

/* 内容区域 */
.content-section {
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.content-box {
  background: #f8f9fa;
  padding: 24rpx;
  border-radius: 12rpx;
  font-size: 32rpx;
  color: #333;
  word-break: break-all;
  line-height: 1.6;
}

/* 图书信息 */
.book-basic {
  margin-bottom: 30rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.book-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #333;
  line-height: 1.4;
  margin-bottom: 12rpx;
}

.book-author {
  font-size: 30rpx;
  color: #666;
}

/* 详细信息列表 */
.info-section {
  margin-top: 20rpx;
}

.info-item {
  display: flex;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: #666;
}

.info-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  max-width: 60%;
  text-align: right;
}

.info-value.available {
  color: #4caf50;
}

.info-value.unavailable {
  color: #f44336;
}

/* 操作栏 */
.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.08);
  display: flex;
  gap: 20rpx;
}

.action-bar .btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100rpx;
  border-radius: 16rpx;
}

.btn-icon {
  font-size: 40rpx;
  margin-bottom: 4rpx;
}
