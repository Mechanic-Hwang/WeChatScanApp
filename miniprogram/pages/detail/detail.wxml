<!-- pages/detail/detail.wxml -->
<view class="container">
  <!-- 普通模式详情 -->
  <view class="detail-card" wx:if="{{record.mode === 'normal'}}">
    <view class="card-header">
      <text class="type-tag normal">普通条码</text>
      <text class="time">{{record.time}}</text>
    </view>
    
    <view class="content-section">
      <view class="section-title">条码内容</view>
      <view class="content-box">{{record.content}}</view>
    </view>
    
    <view class="info-section" wx:if="{{record.type}}">
      <view class="info-item">
        <text class="info-label">类型</text>
        <text class="info-value">{{typeText}}</text>
      </view>
    </view>
  </view>

  <!-- 图书模式详情 -->
  <view class="detail-card book" wx:if="{{record.mode === 'book'}}">
    <view class="card-header">
      <text class="type-tag book">图书信息</text>
      <text class="time">{{record.time}}</text>
    </view>
    
    <!-- 图书基本信息 -->
    <view class="book-basic">
      <view class="book-title">{{bookInfo.title || '未知书名'}}</view>
      <view class="book-author" wx:if="{{bookInfo.author}}">{{bookInfo.author}}</view>
    </view>
    
    <!-- 图书详细信息 -->
    <view class="info-section">
      <view class="section-title">详细信息</view>
      
      <view class="info-item" wx:if="{{bookInfo.isbn}}">
        <text class="info-label">ISBN</text>
        <text class="info-value">{{bookInfo.isbn}}</text>
      </view>
      
      <view class="info-item" wx:if="{{bookInfo.publisher}}">
        <text class="info-label">出版社</text>
        <text class="info-value">{{bookInfo.publisher}}</text>
      </view>
      
      <view class="info-item" wx:if="{{bookInfo.place}}">
        <text class="info-label">出版地</text>
        <text class="info-value">{{bookInfo.place}}</text>
      </view>
      
      <view class="info-item" wx:if="{{bookInfo.year}}">
        <text class="info-label">出版年份</text>
        <text class="info-value">{{bookInfo.year}}</text>
      </view>
      
      <view class="info-item" wx:if="{{bookInfo.callNumber}}">
        <text class="info-label">索书号</text>
        <text class="info-value">{{bookInfo.callNumber}}</text>
      </view>
      
      <view class="info-item">
        <text class="info-label">条码号</text>
        <text class="info-value">{{record.content}}</text>
      </view>
      
      <view class="info-item" wx:if="{{bookInfo.status}}">
        <text class="info-label">馆藏状态</text>
        <text class="info-value {{bookInfo.status === 'Item in place' ? 'available' : 'unavailable'}}">
          {{bookInfo.status}}
        </text>
      </view>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="action-bar">
    <view class="btn btn-primary" bindtap="copyContent">
      <text class="btn-icon">📋</text>
      <text>复制内容</text>
    </view>
    <view class="btn btn-secondary" bindtap="shareContent">
      <text class="btn-icon">📤</text>
      <text>分享</text>
    </view>
    <view class="btn btn-danger" bindtap="deleteRecord">
      <text class="btn-icon">🗑️</text>
      <text>删除</text>
    </view>
  </view>
</view>
