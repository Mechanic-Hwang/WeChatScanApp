/* pages/history/history.wxss
 * History uses WeUI-like filter chips, white record cells, subtle dividers,
 * and a fixed bottom action bar with larger icons for thumb use.
 */
/* 搜索栏 */
.search-bar {
  display: flex;
  align-items: center;
  background: #fff;
  border: 1rpx solid #D8D8D8;
  border-radius: 8rpx;
  margin: 20rpx;
  padding: 20rpx 24rpx;
  box-shadow: none;
}

.search-icon {
  font-size: 32rpx;
  color: #999;
  margin-right: 16rpx;
}

.search-input {
  flex: 1;
  font-size: 30rpx;
  color: #191919;
  background: transparent;
  border: none;
}

.search-input::placeholder {
  color: #bbb;
}

.recent-searches,
.filter-bar,
.page-size-bar,
.pagination {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
  margin: 0 20rpx 20rpx;
}

.recent-chip,
.filter-chip,
.page-size,
.page-btn {
  background: #fff;
  border: 1rpx solid #D8D8D8;
  border-radius: 8rpx;
  color: #666666;
  font-size: 24rpx;
  padding: 10rpx 18rpx;
}

.recent-delete {
  color: #86909c;
  margin-left: 12rpx;
}

.filter-chip.active,
.page-size.active {
  background: #F0FFF7;
  border-color: #07C160;
  color: #07C160;
}

.page-size-label,
.page-info {
  color: #86909c;
  font-size: 24rpx;
}

.pagination {
  justify-content: center;
  padding-bottom: 140rpx;
}

.page-btn.disabled {
  background: #f2f3f5;
  color: #c9cdd4;
  pointer-events: none;
}

/* 批次列表 */
.batch-list {
  padding: 0 20rpx 120rpx;
}

.batch-item {
  display: flex;
  align-items: flex-start;
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid #EEEEEE;
  box-shadow: none;
  transition: all 0.2s;
}

.batch-item.selected {
  background: #F0FFF7;
  border: 1rpx solid #07C160;
}

.batch-item:active {
  transform: scale(0.98);
}

/* 复选框 */
.checkbox-wrapper {
  padding: 10rpx;
  margin: -10rpx;
  margin-right: 10rpx;
}

.checkbox {
  width: 44rpx;
  height: 44rpx;
  border: 2rpx solid #ddd;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
}

.checkbox.checked {
  background: #07C160;
  border-color: #07C160;
  color: #fff;
  font-size: 24rpx;
}

/* 批次内容 */
.batch-content {
  flex: 1;
  min-width: 0;
}

.batch-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.batch-type-tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.batch-type-tag.book {
  background: #F0FFF7;
  color: #07C160;
}

.batch-type-tag.normal {
  background: #F7F8FA;
  color: #576B95;
}

.batch-time {
  font-size: 24rpx;
  color: #999;
}

.batch-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #191919;
  margin-bottom: 16rpx;
}

/* 预览内容 */
.batch-preview {
  background: #F7F8FA;
  border-radius: 8rpx;
  padding: 16rpx;
  margin-bottom: 16rpx;
}

.preview-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 8rpx;
}

.preview-item:last-child {
  margin-bottom: 0;
}

.preview-dot {
  color: #999;
  margin-right: 8rpx;
  font-size: 24rpx;
}

.preview-text {
  font-size: 26rpx;
  color: #666666;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
}

/* 数量 */
.batch-count {
  font-size: 26rpx;
  color: #576B95;
  font-weight: 500;
}

/* 箭头 */
.batch-arrow {
  color: #ccc;
  font-size: 32rpx;
  margin-left: 16rpx;
  align-self: center;
}

/* 顶部操作栏 */
.action-bar {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  padding: 0 20rpx 20rpx;
}

.action-bar .action-btn {
  padding: 12rpx 24rpx;
  border-radius: 8rpx;
  font-size: 26rpx;
  background: #F7F8FA;
  color: #576B95;
  border: 1rpx solid #D8D8D8;
}

.action-bar .action-btn.danger {
  background: #fff0f0;
  color: #ff6b6b;
  border-color: #ff6b6b;
}

/* 底部操作栏 */
.bottom-action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 18rpx 24rpx;
  padding-bottom: calc(18rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #E5E5E5;
  box-shadow: none;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 20rpx;
}

.action-info {
  flex: 1;
}

.selected-text {
  font-size: 30rpx;
  color: #191919;
  font-weight: 500;
}

.action-buttons {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 88rpx;
  padding: 0 30rpx;
  border-radius: 10rpx;
  font-size: 28rpx;
  font-weight: 500;
  line-height: 1;
}

.action-btn.copy {
  background: #07C160;
  color: #fff;
}

.action-btn.delete {
  background: #FA5151;
  color: #fff;
}

.btn-icon {
  position: relative;
  width: 52rpx;
  height: 52rpx;
  margin-right: 10rpx;
  flex-shrink: 0;
  color: currentColor;
}

/* CSS icons keep the bottom action bar consistent with Mini Program controls. */
.copy-icon-back,
.copy-icon-front {
  position: absolute;
  border: 4rpx solid currentColor;
  border-radius: 4rpx;
  box-sizing: border-box;
}

.copy-icon-back {
  width: 26rpx;
  height: 30rpx;
  left: 10rpx;
  top: 8rpx;
  opacity: 0.65;
}

.copy-icon-front {
  width: 28rpx;
  height: 32rpx;
  left: 18rpx;
  top: 14rpx;
  background: transparent;
}

.delete-icon-lid {
  position: absolute;
  left: 12rpx;
  top: 10rpx;
  width: 28rpx;
  height: 4rpx;
  border-radius: 4rpx;
  background: currentColor;
}

.delete-icon-body {
  position: absolute;
  left: 14rpx;
  top: 18rpx;
  width: 24rpx;
  height: 26rpx;
  border: 4rpx solid currentColor;
  border-top: none;
  border-radius: 0 0 5rpx 5rpx;
  box-sizing: border-box;
}
