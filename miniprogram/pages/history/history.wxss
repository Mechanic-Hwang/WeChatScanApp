/* pages/history/history.wxss */
/* 搜索栏 */
.search-bar {
  display: flex;
  align-items: center;
  background: #fff;
  border: 2rpx solid #D8E6FF;
  border-radius: 16rpx;
  margin: 20rpx;
  padding: 20rpx 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(29, 111, 234, 0.06);
}

.search-icon {
  font-size: 32rpx;
  color: #999;
  margin-right: 16rpx;
}

.search-input {
  flex: 1;
  font-size: 30rpx;
  color: #1F2329;
  background: transparent;
  border: none;
}

.search-input::placeholder {
  color: #bbb;
}

.recent-searches,
.filter-bar,
.page-size-bar,
.pagination {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
  margin: 0 20rpx 20rpx;
}

.recent-chip,
.filter-chip,
.page-size,
.page-btn {
  background: #fff;
  border: 2rpx solid #D8E6FF;
  border-radius: 10rpx;
  color: #4e5969;
  font-size: 24rpx;
  padding: 10rpx 18rpx;
}

.recent-delete {
  color: #86909c;
  margin-left: 12rpx;
}

.filter-chip.active,
.page-size.active {
  background: #EAF2FF;
  border-color: #1D6FEA;
  color: #1D6FEA;
}

.page-size-label,
.page-info {
  color: #86909c;
  font-size: 24rpx;
}

.pagination {
  justify-content: center;
  padding-bottom: 140rpx;
}

.page-btn.disabled {
  background: #f2f3f5;
  color: #c9cdd4;
  pointer-events: none;
}

/* 批次列表 */
.batch-list {
  padding: 0 20rpx 120rpx;
}

.batch-item {
  display: flex;
  align-items: flex-start;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid #E6F0FF;
  box-shadow: 0 2rpx 10rpx rgba(29, 111, 234, 0.05);
  transition: all 0.2s;
}

.batch-item.selected {
  background: #EAF2FF;
  border: 2rpx solid #1D6FEA;
}

.batch-item:active {
  transform: scale(0.98);
}

/* 复选框 */
.checkbox-wrapper {
  padding: 10rpx;
  margin: -10rpx;
  margin-right: 10rpx;
}

.checkbox {
  width: 44rpx;
  height: 44rpx;
  border: 2rpx solid #ddd;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
}

.checkbox.checked {
  background: #1D6FEA;
  border-color: #1D6FEA;
  color: #fff;
  font-size: 24rpx;
}

/* 批次内容 */
.batch-content {
  flex: 1;
  min-width: 0;
}

.batch-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.batch-type-tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.batch-type-tag.book {
  background: #EDF6FF;
  color: #0B78D0;
}

.batch-type-tag.normal {
  background: #EAF2FF;
  color: #1D6FEA;
}

.batch-time {
  font-size: 24rpx;
  color: #999;
}

.batch-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1F2329;
  margin-bottom: 16rpx;
}

/* 预览内容 */
.batch-preview {
  background: #F7FAFF;
  border-radius: 12rpx;
  padding: 16rpx;
  margin-bottom: 16rpx;
}

.preview-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 8rpx;
}

.preview-item:last-child {
  margin-bottom: 0;
}

.preview-dot {
  color: #999;
  margin-right: 8rpx;
  font-size: 24rpx;
}

.preview-text {
  font-size: 26rpx;
  color: #4E5969;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
}

/* 数量 */
.batch-count {
  font-size: 26rpx;
  color: #1D6FEA;
  font-weight: 500;
}

/* 箭头 */
.batch-arrow {
  color: #ccc;
  font-size: 32rpx;
  margin-left: 16rpx;
  align-self: center;
}

/* 顶部操作栏 */
.action-bar {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  padding: 0 20rpx 20rpx;
}

.action-bar .action-btn {
  padding: 12rpx 24rpx;
  border-radius: 8rpx;
  font-size: 26rpx;
  background: #EAF2FF;
  color: #1D6FEA;
  border: 1rpx solid #1D6FEA;
}

.action-bar .action-btn.danger {
  background: #fff0f0;
  color: #ff6b6b;
  border-color: #ff6b6b;
}

/* 底部操作栏 */
.bottom-action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 20rpx rgba(29, 111, 234, 0.08);
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.action-info {
  flex: 1;
}

.selected-text {
  font-size: 30rpx;
  color: #1F2329;
  font-weight: 500;
}

.action-buttons {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  display: flex;
  align-items: center;
  padding: 16rpx 32rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.action-btn.copy {
  background: #1D6FEA;
  color: #fff;
}

.action-btn.delete {
  background: #FA5151;
  color: #fff;
}

.btn-icon {
  margin-right: 8rpx;
}
