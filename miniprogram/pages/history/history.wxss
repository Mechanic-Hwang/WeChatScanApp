/* pages/history/history.wxss */
.page-header {
  padding: 30rpx;
  background: #fff;
  margin-bottom: 20rpx;
}

/* 搜索栏 */
.search-bar {
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 12rpx;
  margin: 0 20rpx 20rpx;
  padding: 16rpx 24rpx;
  position: relative;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  background: transparent;
  border: none;
  padding-right: 60rpx;
}

.search-input::placeholder {
  color: #999;
}

.search-icon {
  position: absolute;
  right: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 32rpx;
  color: #999;
}

.page-title {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.page-subtitle {
  font-size: 26rpx;
  color: #999;
}

/* 批次列表 */
.batch-list {
  padding: 0 20rpx 120rpx;
}

.batch-item {
  display: flex;
  align-items: flex-start;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  transition: all 0.2s;
}

.batch-item.selected {
  background: #f0f4ff;
  border: 2rpx solid #667eea;
}

.batch-item:active {
  transform: scale(0.98);
}

/* 复选框 */
.checkbox-wrapper {
  padding: 10rpx;
  margin: -10rpx;
  margin-right: 10rpx;
}

.checkbox {
  width: 44rpx;
  height: 44rpx;
  border: 2rpx solid #ddd;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
}

.checkbox.checked {
  background: #667eea;
  border-color: #667eea;
  color: #fff;
  font-size: 24rpx;
}

/* 批次内容 */
.batch-content {
  flex: 1;
  min-width: 0;
}

.batch-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.batch-type-tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.batch-type-tag.book {
  background: #e8f5e9;
  color: #388e3c;
}

.batch-type-tag.normal {
  background: #e3f2fd;
  color: #1976d2;
}

.batch-time {
  font-size: 24rpx;
  color: #999;
}

.batch-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

/* 预览内容 */
.batch-preview {
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 16rpx;
  margin-bottom: 16rpx;
}

.preview-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 8rpx;
}

.preview-item:last-child {
  margin-bottom: 0;
}

.preview-dot {
  color: #999;
  margin-right: 8rpx;
  font-size: 24rpx;
}

.preview-text {
  font-size: 26rpx;
  color: #666;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
}

/* 数量 */
.batch-count {
  font-size: 26rpx;
  color: #667eea;
  font-weight: 500;
}

/* 箭头 */
.batch-arrow {
  color: #ccc;
  font-size: 32rpx;
  margin-left: 16rpx;
  align-self: center;
}

/* 顶部操作栏 */
.action-bar {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  padding: 0 20rpx 20rpx;
}

.action-bar .action-btn {
  padding: 12rpx 24rpx;
  border-radius: 8rpx;
  font-size: 26rpx;
  background: #f0f4ff;
  color: #667eea;
  border: 1rpx solid #667eea;
}

.action-bar .action-btn.danger {
  background: #fff0f0;
  color: #ff6b6b;
  border-color: #ff6b6b;
}

/* 底部操作栏 */
.bottom-action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.1);
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.action-info {
  flex: 1;
}

.selected-text {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

.action-buttons {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  display: flex;
  align-items: center;
  padding: 16rpx 32rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.action-btn.copy {
  background: #667eea;
  color: #fff;
}

.action-btn.delete {
  background: #ff4757;
  color: #fff;
}

.btn-icon {
  margin-right: 8rpx;
}
