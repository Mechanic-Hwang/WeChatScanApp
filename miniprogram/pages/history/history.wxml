<!-- pages/history/history.wxml -->
<view class="container">
  <!-- 搜索栏 -->
  <view class="search-bar" wx:if="{{batches.length > 0}}">
    <view class="search-icon"></view>
    <input class="search-input"
           type="text"
           placeholder="{{t.searchPlaceholder}}"
           value="{{searchKeyword}}"
           bindinput="onSearchInput"
           bindconfirm="onSearchConfirm"
           confirm-type="search"/>
  </view>

  <view class="recent-searches" wx:if="{{recentSearches.length > 0}}">
    <view class="recent-chip" wx:for="{{recentSearches}}" wx:key="*this">
      <text catchtap="useRecentSearch" data-keyword="{{item}}">{{item}}</text>
      <view class="recent-delete" catchtap="deleteRecentSearch" data-keyword="{{item}}"></view>
    </view>
  </view>

  <view class="filter-bar" wx:if="{{allBatches.length > 0}}">
    <view class="filter-chip {{modeFilter === 'all' ? 'active' : ''}}" bindtap="setModeFilter" data-mode="all">{{t.all}}</view>
    <view class="filter-chip {{modeFilter === 'normal' ? 'active' : ''}}" bindtap="setModeFilter" data-mode="normal">{{t.normal}}</view>
    <view class="filter-chip {{modeFilter === 'book' ? 'active' : ''}}" bindtap="setModeFilter" data-mode="book">{{t.book}}</view>
  </view>

  <view class="filter-bar" wx:if="{{allBatches.length > 0}}">
    <view class="filter-chip {{dateFilter === 'all' ? 'active' : ''}}" bindtap="setDateFilter" data-date="all">{{t.dateAll}}</view>
    <view class="filter-chip {{dateFilter === 'today' ? 'active' : ''}}" bindtap="setDateFilter" data-date="today">{{t.today}}</view>
    <view class="filter-chip {{dateFilter === '7days' ? 'active' : ''}}" bindtap="setDateFilter" data-date="7days">{{t.recent7Days}}</view>
    <view class="filter-chip {{dateFilter === '30days' ? 'active' : ''}}" bindtap="setDateFilter" data-date="30days">{{t.recent30Days}}</view>
  </view>

  <!-- 操作栏 -->
  <view class="action-bar" wx:if="{{allBatches.length > 0}}">
    <view class="action-btn" bindtap="selectAll">
      <text>{{isAllSelected ? t.cancelSelectAll : t.selectAll}}</text>
    </view>
    <view class="action-btn danger" bindtap="clearAllHistory">
      <text>{{t.clearAll}}</text>
    </view>
  </view>

  <view class="page-size-bar" wx:if="{{totalCount > 0}}">
    <text class="page-size-label">{{t.perPage}}</text>
    <view class="page-size {{pageSize === item ? 'active' : ''}}"
          wx:for="{{pageSizes}}"
          wx:key="*this"
          bindtap="setPageSize"
          data-size="{{item}}">{{item}}</view>
  </view>

  <!-- 批次列表 -->
  <view class="batch-list" wx:if="{{batches.length > 0}}">
    <view class="batch-item {{item.selected ? 'selected' : ''}}" 
          wx:for="{{batches}}" 
          wx:key="batchId"
          data-id="{{item.batchId}}"
          bindtap="onBatchTap">
      
      <!-- 复选框 -->
      <view class="checkbox-wrapper" catchtap="onCheckboxTap" data-id="{{item.batchId}}">
        <view class="checkbox {{item.selected ? 'checked' : ''}}">
          <text wx:if="{{item.selected}}">✓</text>
        </view>
      </view>
      
      <!-- 批次内容 -->
      <view class="batch-content">
        <!-- 头部信息 -->
        <view class="batch-header">
          <view class="batch-type-tag {{item.batchType}}">
            {{item.typeText}}
          </view>
          <text class="batch-time">{{item.timeText}}</text>
        </view>
        
        <!-- 批次标题 -->
        <view class="batch-title">{{item.title}}</view>
        
        <!-- 内容预览 -->
        <view class="batch-preview" wx:if="{{item.previewItems.length > 0}}">
          <view class="preview-item" wx:for="{{item.previewItems}}" wx:key="index" wx:for-item="preview">
            <text class="preview-dot">•</text>
            <text class="preview-text">{{preview}}</text>
          </view>
        </view>
        
        <!-- 数量 -->
        <view class="batch-count">{{t.itemCountFull.replace('{count}', item.itemCount)}}</view>
      </view>
      
      <!-- 箭头 -->
      <view class="batch-arrow"></view>
    </view>
  </view>

  <view class="pagination" wx:if="{{totalCount > 0}}">
    <view class="page-btn {{pageIndex <= 1 ? 'disabled' : ''}}" bindtap="prevPage">{{t.prevPage}}</view>
    <text class="page-info">{{pageIndex}} / {{totalPages}} · {{t.batchCount.replace('{count}', totalCount)}}</text>
    <view class="page-btn {{pageIndex >= totalPages ? 'disabled' : ''}}" bindtap="nextPage">{{t.nextPage}}</view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{allBatches.length === 0}}">
    <text class="empty-title">{{t.noHistory}}</text>
    <text class="empty-subtitle">{{t.emptyHistoryTip}}</text>
    <view class="empty-scan-btn" bindtap="goToScan">
      <view class="empty-scan-icon">
        <view class="scan-corner top-left"></view>
        <view class="scan-corner top-right"></view>
        <view class="scan-corner bottom-left"></view>
        <view class="scan-corner bottom-right"></view>
      </view>
      <text>{{t.goToScan}}</text>
    </view>
  </view>

  <view class="empty-state" wx:if="{{allBatches.length > 0 && batches.length === 0}}">
    <view class="empty-icon"></view>
    <text class="empty-title">{{t.noMatchedResults}}</text>
    <text class="empty-subtitle">{{t.noMatchedResultsTip}}</text>
  </view>

  <!-- 底部操作栏 -->
  <view class="bottom-action-bar" wx:if="{{selectedCount > 0}}">
    <view class="action-info">
      <text class="selected-text">{{t.selectedBatches.replace('{count}', selectedCount)}}</text>
    </view>
    <view class="action-buttons">
      <view class="action-btn copy" bindtap="copySelected">
        <view class="btn-icon copy-icon">
          <view class="copy-icon-back"></view>
          <view class="copy-icon-front"></view>
        </view>
        <text>{{t.copy}}</text>
      </view>
      <view class="action-btn delete" bindtap="deleteSelected">
        <view class="btn-icon delete-icon">
          <view class="delete-icon-lid"></view>
          <view class="delete-icon-body"></view>
        </view>
        <text>{{t.delete}}</text>
      </view>
    </view>
  </view>
</view>
