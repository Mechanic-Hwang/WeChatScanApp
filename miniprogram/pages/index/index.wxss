/* pages/index/index.wxss
 * Home follows WeUI visual rhythm: green primary scan action,
 * neutral segmented mode switch, and readable 15pt-ish list text.
 */
/* 模式切换 */
.mode-switch {
  padding: 30rpx;
}

.mode-label {
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 20rpx;
}

.mode-toggle {
  display: flex;
  background: #F2F2F2;
  border-radius: 8rpx;
  padding: 6rpx;
}

.mode-option {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 0;
  border-radius: 6rpx;
  transition: all 0.3s;
}

.mode-option.active {
  background: #fff;
  border: 1rpx solid #E5E5E5;
}

.mode-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  border: 1rpx solid #D8D8D8;
  font-size: 28rpx;
  font-weight: 600;
  color: #576B95;
  margin-bottom: 8rpx;
}

.mode-text {
  font-size: 26rpx;
  color: #666666;
}

.mode-option.active .mode-text {
  color: #07C160;
  font-weight: 500;
}

.mode-option.active .mode-icon {
  border-color: #07C160;
  color: #07C160;
  background: #F0FFF7;
}

/* 扫码区域 */
.scan-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
}

.scan-btn {
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  background: #07C160;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  transition: transform 0.2s;
}

.scan-btn:active {
  transform: scale(0.95);
}

.scan-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.9);
  font-size: 42rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 10rpx;
}

.scan-text {
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
}

.scan-tip {
  margin-top: 30rpx;
  font-size: 26rpx;
  color: #8A8A8A;
}

/* 输入区域 */
.input-section {
  padding: 30rpx;
}

.input-label {
  font-size: 28rpx;
  color: #191919;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.btn.disabled {
  background: #C9CDD4;
  color: #fff;
  pointer-events: none;
}

.textarea-input {
  min-height: 144rpx;
  height: auto;
  line-height: 1.5;
  padding-top: 20rpx;
  padding-bottom: 20rpx;
}

/* 完成扫描 */
.finish-section {
  padding: 0 30rpx;
  margin-bottom: 20rpx;
}

/* 最近记录 */
.history-section {
  padding: 30rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #191919;
}

.view-all {
  font-size: 26rpx;
  color: #576B95;
}

.record-list {
  margin-top: 10rpx;
}

.record-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.record-item:last-child {
  border-bottom: none;
}

.record-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  font-size: 26rpx;
  font-weight: 600;
  margin-right: 20rpx;
}

.record-icon.book {
  background: #F0FFF7;
  color: #07C160;
}

.record-icon.normal {
  background: #F7F8FA;
  color: #576B95;
}

.record-content {
  flex: 1;
  min-width: 0;
}

.record-title {
  font-size: 30rpx;
  color: #191919;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.record-meta {
  font-size: 24rpx;
  color: #8A8A8A;
  margin-top: 8rpx;
}

.record-arrow {
  color: #ccc;
  font-size: 32rpx;
}
