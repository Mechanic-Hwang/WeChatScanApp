/* pages/index/index.wxss */
/* 模式切换 */
.mode-switch {
  padding: 30rpx;
}

.mode-label {
  font-size: 28rpx;
  color: #4E5969;
  margin-bottom: 20rpx;
}

.mode-toggle {
  display: flex;
  background: #EAF2FF;
  border-radius: 16rpx;
  padding: 6rpx;
}

.mode-option {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 0;
  border-radius: 12rpx;
  transition: all 0.3s;
}

.mode-option.active {
  background: #fff;
  box-shadow: 0 4rpx 16rpx rgba(29, 111, 234, 0.12);
}

.mode-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.mode-text {
  font-size: 26rpx;
  color: #4E5969;
}

.mode-option.active .mode-text {
  color: #1D6FEA;
  font-weight: 500;
}

/* 扫码区域 */
.scan-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
}

.scan-btn {
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  background: #1D6FEA;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 34rpx rgba(29, 111, 234, 0.24);
  transition: transform 0.2s;
}

.scan-btn:active {
  transform: scale(0.95);
}

.scan-icon {
  font-size: 80rpx;
  margin-bottom: 10rpx;
}

.scan-text {
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
}

.scan-tip {
  margin-top: 30rpx;
  font-size: 26rpx;
  color: #86909C;
}

/* 输入区域 */
.input-section {
  padding: 30rpx;
}

.input-label {
  font-size: 28rpx;
  color: #1F2329;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.btn.disabled {
  background: #C9CDD4;
  color: #fff;
  pointer-events: none;
}

.textarea-input {
  min-height: 144rpx;
  height: auto;
  line-height: 1.5;
  padding-top: 20rpx;
  padding-bottom: 20rpx;
}

/* 完成扫描 */
.finish-section {
  padding: 0 30rpx;
  margin-bottom: 20rpx;
}

/* 最近记录 */
.history-section {
  padding: 30rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1F2329;
}

.view-all {
  font-size: 26rpx;
  color: #1D6FEA;
}

.record-list {
  margin-top: 10rpx;
}

.record-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.record-item:last-child {
  border-bottom: none;
}

.record-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.record-content {
  flex: 1;
  min-width: 0;
}

.record-title {
  font-size: 30rpx;
  color: #1F2329;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.record-meta {
  font-size: 24rpx;
  color: #86909C;
  margin-top: 8rpx;
}

.record-arrow {
  color: #ccc;
  font-size: 32rpx;
}
