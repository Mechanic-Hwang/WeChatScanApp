<!-- pages/index/index.wxml -->
<view class="container">
  <!-- 模式切换 -->
  <view class="card mode-switch">
    <view class="mode-toggle">
      <view class="mode-option {{currentMode === 'normal' ? 'active' : ''}}" 
            bindtap="switchMode" data-mode="normal">
        <view class="mode-icon scan-mark">
          <view class="scan-corner top-left"></view>
          <view class="scan-corner top-right"></view>
          <view class="scan-corner bottom-left"></view>
          <view class="scan-corner bottom-right"></view>
        </view>
        <text class="mode-text">{{t.normalMode}}</text>
      </view>
      <view class="mode-option {{currentMode === 'book' ? 'active' : ''}}" 
            bindtap="switchMode" data-mode="book">
        <view class="mode-icon book-mark">
          <view class="book-page left"></view>
          <view class="book-page right"></view>
        </view>
        <text class="mode-text">{{t.bookMode}}</text>
      </view>
    </view>
  </view>

  <!-- 扫码按钮 -->
  <view class="scan-section">
    <view class="scan-btn" bindtap="startScan">
      <view class="scan-icon scan-mark">
        <view class="scan-corner top-left"></view>
        <view class="scan-corner top-right"></view>
        <view class="scan-corner bottom-left"></view>
        <view class="scan-corner bottom-right"></view>
      </view>
      <text class="scan-text">{{t.clickToScan}}</text>
    </view>
    <text class="scan-tip">{{currentMode === 'book' ? t.supportBook : t.supportQR}}</text>
  </view>

  <!-- 手动输入 -->
  <view class="card input-section">
    <view class="input-title-row">
      <view class="input-title-icon edit-mark"></view>
      <view class="input-label">{{t.manualInput}}</view>
    </view>
    <input wx:if="{{!inputRules.allowNewline}}"
           class="input" 
           type="text" 
           placeholder="{{currentMode === 'book' ? t.inputBookPlaceholder : t.inputPlaceholder}}"
           value="{{inputValue}}"
           maxlength="{{inputRules.maxLength}}"
           bindinput="onInputChange"
           confirm-type="done"
           bindconfirm="onInputConfirm"/>
    <textarea wx:else
              class="input textarea-input"
              placeholder="{{currentMode === 'book' ? t.inputBookPlaceholder : t.inputPlaceholder}}"
              value="{{inputValue}}"
              maxlength="{{inputRules.maxLength}}"
              auto-height
              bindinput="onInputChange"/>
    <view class="btn btn-primary mt-20 {{isLoading ? 'disabled' : ''}}" bindtap="onManualInput">{{isLoading ? t.querying : t.confirmBtn}}</view>
  </view>

  <!-- 完成扫描按钮 -->
  <view class="finish-section" wx:if="{{currentBatchHasRecords}}">
    <view class="btn btn-secondary" bindtap="finishScan">{{t.finishScan}}</view>
  </view>

  <!-- 最近批次 -->
  <view class="card history-section" wx:if="{{recentBatches.length > 0}}">
    <view class="section-header">
      <text class="section-title">{{t.recentBatches}}</text>
      <text class="view-all" bindtap="viewAllHistory">{{t.viewAll}} ></text>
    </view>
    
    <view class="record-list">
      <view class="record-item" 
            wx:for="{{recentBatches}}" 
            wx:key="batchId"
            bindtap="viewBatchDetail"
            data-id="{{item.batchId}}">
        <view class="record-icon {{item.batchType === 'book' ? 'book' : 'normal'}}">
          <view wx:if="{{item.batchType === 'book'}}" class="book-mark small">
            <view class="book-page left"></view>
            <view class="book-page right"></view>
          </view>
          <view wx:else class="scan-mark small">
            <view class="scan-corner top-left"></view>
            <view class="scan-corner top-right"></view>
            <view class="scan-corner bottom-left"></view>
            <view class="scan-corner bottom-right"></view>
          </view>
        </view>
        <view class="record-content">
          <view class="record-title">{{item.title}}</view>
          <view class="record-meta">{{item.time}} · {{t.itemCountFull.replace('{count}', item.itemCount)}}</view>
        </view>
        <text class="record-arrow">></text>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{recentBatches.length === 0}}">
    <view class="empty-icon"></view>
    <text class="empty-text">{{t.noRecords}}</text>
    <text class="empty-subtext">{{t.startScanTip}}</text>
  </view>
</view>
