/* pages/history-detail/history-detail.wxss
 * Detail keeps the same WeUI treatment as history: clear record cells,
 * muted metadata, and a bottom action bar with enlarged action icons.
 */
.batch-header-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid #EEEEEE;
  box-shadow: none;
}

.batch-type-tag {
  display: inline-block;
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
  font-size: 26rpx;
  margin-bottom: 16rpx;
}

.batch-type-tag.book {
  background: #F0FFF7;
  color: #07C160;
}

.batch-type-tag.normal {
  background: #F7F8FA;
  color: #576B95;
}

.batch-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #191919;
  margin-bottom: 16rpx;
}

.batch-meta {
  display: flex;
  gap: 20rpx;
}

.meta-item {
  font-size: 26rpx;
  color: #999;
}

.page-size-bar,
.pagination {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.page-size-label,
.page-info {
  color: #86909c;
  font-size: 24rpx;
}

.page-size,
.page-btn {
  background: #fff;
  border: 1rpx solid #D8D8D8;
  border-radius: 8rpx;
  color: #666666;
  font-size: 24rpx;
  padding: 10rpx 18rpx;
}

.page-size.active {
  background: #F0FFF7;
  border-color: #07C160;
  color: #07C160;
}

.pagination {
  justify-content: center;
  padding-bottom: 140rpx;
}

.page-btn.disabled {
  background: #f2f3f5;
  color: #c9cdd4;
  pointer-events: none;
}

/* 结果列表 */
.result-list {
  padding-bottom: 140rpx;
}

.result-item {
  display: flex;
  align-items: flex-start;
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid #EEEEEE;
  box-shadow: none;
}

.result-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
  margin-top: 4rpx;
}

.result-content {
  flex: 1;
  min-width: 0;
}

.result-text {
  font-size: 30rpx;
  color: #191919;
  word-break: break-all;
  line-height: 1.5;
  margin-bottom: 8rpx;
}

.result-time {
  font-size: 24rpx;
  color: #999;
}

/* 图书信息 */
.book-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #191919;
  margin-bottom: 8rpx;
}

.book-author,
.book-barcode,
.book-call {
  font-size: 26rpx;
  color: #666666;
  margin-bottom: 4rpx;
}

.record-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 12rpx;
}

.record-action {
  color: #576B95;
  font-size: 26rpx;
}

.record-action.danger {
  color: #FA5151;
}

/* 底部操作栏 */
.bottom-action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 18rpx 24rpx;
  padding-bottom: calc(18rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #E5E5E5;
  box-shadow: none;
  display: flex;
  gap: 16rpx;
}

.action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 96rpx;
  border-radius: 10rpx;
  font-size: 28rpx;
  font-weight: 500;
  line-height: 1;
}

.action-btn.scan {
  background: #07C160;
  color: #fff;
}

.action-btn.copy {
  background: #F7F8FA;
  color: #576B95;
  border: 1rpx solid #D8D8D8;
}

.action-btn.delete {
  background: #FA5151;
  color: #fff;
}

.btn-icon {
  font-size: 52rpx;
  line-height: 1;
  margin-right: 12rpx;
}
