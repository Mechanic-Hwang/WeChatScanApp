<!-- pages/history-detail/history-detail.wxml -->
<view class="container">
  <!-- 批次头部信息 -->
  <view class="batch-header-card">
    <view class="batch-type-tag {{batch.batchType}}">
      {{batch.typeText}}
    </view>
    <view class="batch-title">{{batch.title}}</view>
    <view class="batch-meta">
      <text class="meta-item">{{batch.timeText}}</text>
      <text class="meta-item">{{t.totalItems}} {{batch.itemCount}} {{t.items}}</text>
    </view>
  </view>

  <view class="page-size-bar" wx:if="{{batch.items.length > 0}}">
    <text class="page-size-label">{{t.perPage}}</text>
    <view class="page-size {{pageSize === item ? 'active' : ''}}"
          wx:for="{{pageSizes}}"
          wx:key="*this"
          bindtap="setPageSize"
          data-size="{{item}}">{{item}}</view>
  </view>

  <!-- 结果列表 -->
  <view class="result-list">
    <view class="result-item" 
          wx:for="{{pagedItems}}" 
          wx:key="id">
      
      <!-- 普通模式 -->
      <block wx:if="{{item.mode === 'normal'}}">
        <view class="result-icon normal scan-mark">
          <view class="scan-corner top-left"></view>
          <view class="scan-corner top-right"></view>
          <view class="scan-corner bottom-left"></view>
          <view class="scan-corner bottom-right"></view>
        </view>
        <view class="result-content">
          <view class="result-text">{{item.content}}</view>
          <view class="result-time">{{item.timeText}}</view>
          <view class="api-result" wx:if="{{item.apiDisplayFields.length || item.apiConfigId || item.matchedRuleId}}">
            <view class="api-result-title">{{t.interfaceResult}}</view>
            <view class="api-meta" wx:if="{{item.apiConfigId || item.matchedRuleId}}">
              <text wx:if="{{item.apiConfigId}}">{{t.usedApi}} {{item.apiConfigId}}</text>
              <text wx:if="{{item.matchedRuleId}}">{{t.matchedRule}} {{item.matchedRuleId}}</text>
            </view>
            <view class="api-field" wx:for="{{item.apiDisplayFields}}" wx:key="label">
              <text class="api-field-label">{{item.label}}</text>
              <text class="api-field-value">{{item.value || t.noData}}</text>
            </view>
            <scroll-view class="api-raw" wx:if="{{item.rawResponseText}}" scroll-y>{{item.rawResponseText}}</scroll-view>
          </view>
          <view class="record-actions">
            <text class="record-action" catchtap="copyRecord" data-id="{{item.id}}">{{t.copy}}</text>
            <text class="record-action danger" catchtap="deleteRecord" data-id="{{item.id}}">{{t.delete}}</text>
          </view>
        </view>
      </block>
      
      <!-- 图书模式 -->
      <block wx:if="{{item.mode === 'book'}}">
        <view class="result-icon book book-mark">
          <view class="book-page left"></view>
          <view class="book-page right"></view>
        </view>
        <view class="result-content">
          <view class="book-title">{{item.bookInfo.title || t.unknownBookTitle}}</view>
          <view class="book-author" wx:if="{{item.bookInfo.author}}">
            {{t.bookAuthor}}：{{item.bookInfo.author}}
          </view>
          <view class="book-barcode">{{t.bookBarcode}}：{{item.content}}</view>
          <view class="book-call" wx:if="{{item.bookInfo.callNumber}}">
            {{t.bookCallNumber}}：{{item.bookInfo.callNumber}}
          </view>
          <view class="result-time">{{item.timeText}}</view>
          <view class="api-result" wx:if="{{item.apiDisplayFields.length || item.apiConfigId || item.matchedRuleId}}">
            <view class="api-result-title">{{t.interfaceResult}}</view>
            <view class="api-meta" wx:if="{{item.apiConfigId || item.matchedRuleId}}">
              <text wx:if="{{item.apiConfigId}}">{{t.usedApi}} {{item.apiConfigId}}</text>
              <text wx:if="{{item.matchedRuleId}}">{{t.matchedRule}} {{item.matchedRuleId}}</text>
            </view>
            <view class="api-field" wx:for="{{item.apiDisplayFields}}" wx:key="label">
              <text class="api-field-label">{{item.label}}</text>
              <text class="api-field-value">{{item.value || t.noData}}</text>
            </view>
            <scroll-view class="api-raw" wx:if="{{item.rawResponseText}}" scroll-y>{{item.rawResponseText}}</scroll-view>
          </view>
          <view class="record-actions">
            <text class="record-action" catchtap="copyRecord" data-id="{{item.id}}">{{t.copy}}</text>
            <text class="record-action danger" catchtap="deleteRecord" data-id="{{item.id}}">{{t.delete}}</text>
          </view>
        </view>
      </block>
    </view>
  </view>

  <view class="pagination" wx:if="{{batch.items.length > 0}}">
    <view class="page-btn {{pageIndex <= 1 ? 'disabled' : ''}}" bindtap="prevPage">{{t.prevPage}}</view>
    <text class="page-info">{{pageIndex}} / {{totalPages}} · {{t.itemCountFull.replace('{count}', batch.itemCount)}}</text>
    <view class="page-btn {{pageIndex >= totalPages ? 'disabled' : ''}}" bindtap="nextPage">{{t.nextPage}}</view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{batch.items.length === 0}}">
    <view class="empty-icon"></view>
    <text>{{t.emptyBatch}}</text>
  </view>

  <!-- 底部操作栏 -->
  <view class="bottom-action-bar">
    <view class="action-btn scan" bindtap="scanAgain">
      <view class="btn-icon scan-icon-small">
        <view class="scan-corner top-left"></view>
        <view class="scan-corner top-right"></view>
        <view class="scan-corner bottom-left"></view>
        <view class="scan-corner bottom-right"></view>
      </view>
      <text>{{t.scanAgain}}</text>
    </view>
    <view class="action-btn copy" bindtap="copyBatch">
      <view class="btn-icon copy-icon">
        <view class="copy-icon-back"></view>
        <view class="copy-icon-front"></view>
      </view>
      <text>{{t.copyAll}}</text>
    </view>
    <view class="action-btn delete" bindtap="deleteBatch">
      <view class="btn-icon delete-icon">
        <view class="delete-icon-lid"></view>
        <view class="delete-icon-body"></view>
      </view>
      <text>{{t.delete}}</text>
    </view>
  </view>
</view>
