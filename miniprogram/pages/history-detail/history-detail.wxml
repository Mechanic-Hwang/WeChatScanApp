<!-- pages/history-detail/history-detail.wxml -->
<view class="container">
  <!-- 批次头部信息 -->
  <view class="batch-header-card">
    <view class="batch-type-tag {{batch.batchType}}">
      {{batch.batchType === 'book' ? '📚 ' + t.bookScan : '📷 ' + t.normalScan}}
    </view>
    <view class="batch-title">{{batch.title}}</view>
    <view class="batch-meta">
      <text class="meta-item">{{batch.timeText}}</text>
      <text class="meta-item">{{t.totalItems}} {{batch.itemCount}} {{t.items}}</text>
    </view>
  </view>

  <!-- 结果列表 -->
  <view class="result-list">
    <view class="result-item" 
          wx:for="{{batch.items}}" 
          wx:key="id">
      
      <!-- 普通模式 -->
      <block wx:if="{{item.mode === 'normal'}}">
        <view class="result-icon">📷</view>
        <view class="result-content">
          <view class="result-text">{{item.content}}</view>
          <view class="result-time">{{item.timeText}}</view>
        </view>
      </block>
      
      <!-- 图书模式 -->
      <block wx:if="{{item.mode === 'book'}}">
        <view class="result-icon">📚</view>
        <view class="result-content">
          <view class="book-title">{{item.bookInfo.title || t.unknownBookTitle || '未知书名'}}</view>
          <view class="book-author" wx:if="{{item.bookInfo.author}}">
            {{t.bookAuthor}}：{{item.bookInfo.author}}
          </view>
          <view class="book-barcode">{{t.bookBarcode}}：{{item.content}}</view>
          <view class="book-call" wx:if="{{item.bookInfo.callNumber}}">
            {{t.bookCallNumber}}：{{item.bookInfo.callNumber}}
          </view>
        </view>
      </block>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{batch.items.length === 0}}">
    <text class="empty-icon">📭</text>
    <text>{{t.emptyBatch || '该批次没有记录'}}</text>
  </view>

  <!-- 底部操作栏 -->
  <view class="bottom-action-bar">
    <view class="action-btn scan" bindtap="scanAgain">
      <text class="btn-icon">📷</text>
      <text>{{t.scanAgain || '再次扫描'}}</text>
    </view>
    <view class="action-btn copy" bindtap="copyBatch">
      <text class="btn-icon">📋</text>
      <text>{{t.copyAll}}</text>
    </view>
    <view class="action-btn delete" bindtap="deleteBatch">
      <text class="btn-icon">🗑️</text>
      <text>{{t.delete}}</text>
    </view>
  </view>
</view>
